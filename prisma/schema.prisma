// Amplified Growth OS — PostgreSQL + Prisma
// Run: npx prisma generate && npx prisma db push (or migrate)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// System-level (not per-firm). Seed with offer archetypes.
model OfferArchetype {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  bestFitIcpTypes     String[] @default([]) // or Json if preferred
  ctaTemplate         String?
  meetingFormat       String?
  promptTemplateIds   Json?
  createdAt           DateTime @default(now())
  offers              Offer[]
}

model Firm {
  id                String    @id @default(cuid())
  name              String
  websiteUrl        String?
  websiteAnalysis   Json?
  firmDescription   String?   @map("firm_description")
  serviceModel      String?
  aumRange          String?
  primaryFocus      String?
  geography         String?
  createdAt         DateTime  @default(now())
  firmProfile       FirmProfile?
  icpProfiles       IcpProfile[]
  offers            Offer[]
  campaigns         Campaign[]
}

model FirmProfile {
  id               String   @id @default(cuid())
  firmId           String   @unique @map("firm_id")
  firm             Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientAgeRange   String?
  clientSituations  String[] @default([])
  avgHouseholdAum   String?
  householdCount    Int?
  credentials       String[] @default([])
  serviceRadius     String?
  complianceFlags   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model IcpProfile {
  id                    String    @id @default(cuid())
  firmId                String    @map("firm_id")
  firm                  Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  personaLabel          String?
  ageRange              String?
  assetBand             String?
  lifeStage             String?
  primaryConcern        String?
  secondaryConcerns    String[]  @default([])
  emotionalTriggers     String[]  @default([])
  objections            String[]  @default([])
  toneSetting           String?
  archetypeClassification String? @map("archetype_classification")
  version               Int       @default(1)
  status                String?   @default("draft")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  offers                Offer[]
  campaigns             Campaign[]
}

model Offer {
  id             String   @id @default(cuid())
  archetypeId    String   @map("archetype_id")
  archetype     OfferArchetype @relation(fields: [archetypeId], references: [id])
  firmId        String   @map("firm_id")
  firm          Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  icpId         String   @map("icp_id")
  icp           IcpProfile @relation(fields: [icpId], references: [id], onDelete: Cascade)
  meetingType   String?
  meetingLength String?
  customName    String?
  exclusions    String[] @default([])
  status        String?  @default("active")
  createdAt     DateTime @default(now())
  campaigns     Campaign[]
}

model Campaign {
  id           String    @id @default(cuid())
  firmId       String    @map("firm_id")
  firm         Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  icpId        String    @map("icp_id")
  icp          IcpProfile @relation(fields: [icpId], references: [id], onDelete: Cascade)
  offerId      String    @map("offer_id")
  offer        Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  name         String
  channel      String?
  budgetRange   String?
  launchDate   DateTime?
  status       String    @default("in_progress") // in_progress | approved | active | paused
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assetSets    AssetSet[]
  complianceLogs ComplianceLog[]
}

model AssetSet {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category   String   // ad_creative | funnel_copy | sequences | call_prep
  status     String   @default("generating") // generating | in_review | approved
  createdAt  DateTime @default(now())
  assets     Asset[]
}

model Asset {
  id               String         @id @default(cuid())
  assetSetId       String         @map("asset_set_id")
  assetSet         AssetSet       @relation(fields: [assetSetId], references: [id], onDelete: Cascade)
  type             String         // hook | primary_text | headline | email | sms | section | question | rebuttal
  content          String         @db.Text
  version          Int            @default(1)
  status           String         @default("draft") // draft | approved | removed
  generationParams Json?
  createdAt        DateTime       @default(now())
  revisions        AssetRevision[]
}

model AssetRevision {
  id              String   @id @default(cuid())
  assetId         String   @map("asset_id")
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  feedbackType    String?
  feedbackNote    String?  @db.Text
  previousContent String?  @db.Text
  newContent      String?  @db.Text
  version         Int      @default(1)
  createdAt       DateTime @default(now())
}

model ComplianceLog {
  id                      String   @id @default(cuid())
  campaignId               String   @map("campaign_id")
  campaign                 Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  acknowledgments          Json?
  assetVersionsAcknowledged Json?   @map("asset_versions_acknowledged")
  timestamp                DateTime @default(now())
}
