# Copy to .env and fill in values. Never commit .env.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/amplified_os

# APIs (get keys from each provider's dashboard)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# GHL OAuth (from Marketplace → Build → Auth; Secrets → Client Keys)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://localhost:8000/api/connect/oauth/callback
# Optional: version_id from Install Link for draft apps
# GHL_VERSION_ID=

# Optional: webhook signature verification
# GHL_WEBHOOK_SIGNING_SECRET=

# Optional: cron / internal endpoints
# CRON_SECRET=
# META_CRON_SECRET=
# META_APP_SECRET=

# Optional: Google Drive, Vercel Blob, etc.
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_FOLDER_ID=
# BLOB_READ_WRITE_TOKEN=
