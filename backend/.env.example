# Copy to .env and fill in values. Never commit .env.

# Database (app and scripts use DATABASE_URL; keep as local for dev)
DATABASE_URL=postgresql://user:password@localhost:5432/amplified_os
# Optional: production DB URL for running migrations/seeds from your machine:
# DATABASE_URL_PROD=postgresql://...
# Then: DATABASE_URL=$DATABASE_URL_PROD python3 scripts/run_custom_domains_migration.py

# APIs (get keys from each provider's dashboard)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=

# CORS: only your own fixed origins (e.g. local dev, main app URL). Client BYOD domains are allowed automatically from the DB when verified — do not add them here.
CORS_ORIGINS=http://localhost:5173

# BYOD: base domain for platform subdomains (e.g. yourplatform.com -> slug.yourplatform.com = firm_id slug)
# PLATFORM_BASE_DOMAIN=

# BYOD: Vercel API — add/verify custom domains via code (POST /api/domains/connect, POST /api/domains/verify)
# Create token at https://vercel.com/account/tokens. Project ID in Vercel project Settings → General.
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=   # optional; required if project is under a team

# Optional: default firm for messaging webhooks when contact is unknown
# MESSAGING_DEFAULT_FIRM_ID=

# SendBlue (Phase 1 — iMessage / SMS)
# SENDBLUE_API_KEY_ID=
# SENDBLUE_API_SECRET=
# From number (E.164, e.g. +13054098546) — used when sending from Conversations inbox
# SENDBLUE_FROM_NUMBER=

# Resend (Phase 1 — email)
# RESEND_API_KEY=

# Optional: cron / internal endpoints
# CRON_SECRET=
# META_CRON_SECRET=
# META_APP_SECRET=

# Calendly OAuth (Phase 3) — add this exact URI in Calendly app settings
# Use local for dev; uncomment prod and comment local when deploying
CALENDLY_REDIRECT_URI=http://localhost:8000/api/calendly/oauth/callback
# CALENDLY_REDIRECT_URI=https://your-api-domain.com/api/calendly/oauth/callback

# Zoom (Phase 3 — Server-to-Server OAuth app from Zoom Marketplace)
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Mux (Phase 4 — Video API for webinar streaming)
# MUX_ACCESS_TOKEN_ID=
# MUX_SECRET_KEY=

# Optional: Google Drive, Vercel Blob, etc.
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_FOLDER_ID=
# BLOB_READ_WRITE_TOKEN=
