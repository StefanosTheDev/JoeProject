# Copy to .env and fill in values. Never commit .env.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/amplified_os

# APIs (get keys from each provider's dashboard)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# SendBlue (Phase 1 — iMessage / SMS)
# SENDBLUE_API_KEY_ID=
# SENDBLUE_API_SECRET=
# From number (E.164, e.g. +13054098546) — used when sending from Conversations inbox
# SENDBLUE_FROM_NUMBER=

# Resend (Phase 1 — email)
# RESEND_API_KEY=

# Optional: cron / internal endpoints
# CRON_SECRET=
# META_CRON_SECRET=
# META_APP_SECRET=

# Calendly OAuth (Phase 3) — add this exact URI in Calendly app settings
# Use local for dev; uncomment prod and comment local when deploying
CALENDLY_REDIRECT_URI=http://localhost:8000/api/calendly/oauth/callback
# CALENDLY_REDIRECT_URI=https://your-api-domain.com/api/calendly/oauth/callback

# Zoom (Phase 3 — Server-to-Server OAuth app from Zoom Marketplace)
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Mux (Phase 4 — Video API for webinar streaming)
# MUX_ACCESS_TOKEN_ID=
# MUX_SECRET_KEY=

# Optional: Google Drive, Vercel Blob, etc.
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_FOLDER_ID=
# BLOB_READ_WRITE_TOKEN=
